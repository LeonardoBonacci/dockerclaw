{
  "gateway": { "mode": "local" },
  "models": {
    "mode": "replace",
    "providers": {
      "ollama": { "baseUrl": "http://host.docker.internal:11434" }
    }
  },
  "agents": {
    "defaults": { "model": { "primary": "ollama/llama3.1:latest" } },
    "list": [
      {
        "id": "coordinator",
        "default": true,
        "name": "El Capitán",
        "description": "World Cup 2026 party coordinator - assigns topics, collects results, publishes the match day bulletin",
        "model": { "primary": "ollama/llama3.1:latest" },
        "tools": { "profile": "coding" },
        "workspace": "/home/node/workspace"
      }
    ]
  },
  "web": { "enabled": true }
}
